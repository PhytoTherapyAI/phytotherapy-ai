# DoctoPal Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.

# ─── Supabase (required) ─────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── App URL (required — used in invite links, emails) ─
NEXT_PUBLIC_APP_URL=https://doctopal.com

# ─── AI Providers (required) ──────────────────────────
GEMINI_API_KEY=
# Anthropic Claude (if using Claude-specific endpoints)
ANTHROPIC_API_KEY=

# ─── Email (Resend — for family invites, contact form) ─
RESEND_API_KEY=

# ─── Medical Data APIs ────────────────────────────────
PUBMED_API_KEY=

# ─── WhatsApp / SMS Bot (optional) ────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# ─── Telegram Bot (optional) ──────────────────────────
TELEGRAM_BOT_TOKEN=

# ─── Scheduled Jobs (Vercel Cron secret) ──────────────
CRON_SECRET=

# ─── Error Monitoring (optional) ──────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ─── Bot Protection (optional) ────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
